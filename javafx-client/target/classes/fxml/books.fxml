<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.client.controller.BookController">

    <!-- Top: Search and Controls -->
    <top>
        <VBox spacing="10" style="-fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Search:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="searchField" promptText="Search by title or author" onKeyReleased="#handleSearch" prefWidth="300"/>
            </HBox>
            <HBox spacing="10">
                <Button fx:id="addButton" text="Add Book" onAction="#handleAddBook"/>
                <Button fx:id="deleteButton" text="Delete Selected" onAction="#handleDeleteBook"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: Books Table -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="Books Catalogue" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <TableView fx:id="booksTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="bookIdColumn" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="titleColumn" text="Title" prefWidth="150"/>
                    <TableColumn fx:id="authorColumn" text="Author" prefWidth="120"/>
                    <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bottom: Navigation -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 15;">
            <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack"/>
        </HBox>
    </bottom>
</BorderPane>
