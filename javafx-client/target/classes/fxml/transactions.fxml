<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.client.controller.TransactionController">

    <!-- Top: Borrow Form -->
    <top>
        <VBox spacing="10" style="-fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-background-color: #f9f9f9;">
            <Label text="Borrow Book" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Member ID:" style="-fx-min-width: 100;"/>
                <TextField fx:id="memberIdField" promptText="e.g., M001" prefWidth="150"/>
                <Label text="Book ID:" style="-fx-min-width: 80;"/>
                <TextField fx:id="bookIdField" promptText="e.g., B001" prefWidth="150"/>
                <Button fx:id="borrowButton" text="Borrow" onAction="#handleBorrow" style="-fx-padding: 5 20 5 20;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Center: Transaction History -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Transaction History" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Filter:" style="-fx-font-size: 12;"/>
                <ComboBox fx:id="statusFilterCombo" onAction="#handleFilterChange" prefWidth="100"/>
                <Button fx:id="returnButton" text="Return Selected" onAction="#handleReturn" style="-fx-margin-left: 100;"/>
            </HBox>
            <TableView fx:id="historyTable" prefHeight="350">
                <columns>
                    <TableColumn fx:id="recordIdColumn" text="Record ID" prefWidth="80"/>
                    <TableColumn fx:id="bookIdColumn" text="Book ID" prefWidth="80"/>
                    <TableColumn fx:id="memberIdColumn" text="Member ID" prefWidth="100"/>
                    <TableColumn fx:id="borrowDateColumn" text="Borrow Date" prefWidth="100"/>
                    <TableColumn fx:id="returnDateColumn" text="Return Date" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Bottom: Navigation -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 15;">
            <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBack"/>
        </HBox>
    </bottom>
</BorderPane>
