<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.library.client.controller.DashboardController">

    <!-- Left Sidebar Navigation -->
    <left>
        <VBox style="-fx-border-color: #cccccc; -fx-padding: 15;" spacing="10" minWidth="150">
            <Label text="Navigation" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
            <Button fx:id="booksButton" text="Books" onAction="#navigateToBooks" style="-fx-min-width: 130;"/>
            <Button fx:id="membersButton" text="Members" onAction="#navigateToMembers" style="-fx-min-width: 130;"/>
            <Button fx:id="transactionsButton" text="Transactions" onAction="#navigateToTransactions" style="-fx-min-width: 130;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Label text="Dashboard" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

            <!-- Summary Cards -->
            <HBox spacing="20">
                <VBox style="-fx-border-color: #e0e0e0; -fx-padding: 15;" minWidth="150">
                    <Label text="Total Books" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                    <Label fx:id="totalBooksLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-border-color: #e0e0e0; -fx-padding: 15;" minWidth="150">
                    <Label text="Total Members" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                    <Label fx:id="totalMembersLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-border-color: #e0e0e0; -fx-padding: 15;" minWidth="150">
                    <Label text="Active Borrows" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                    <Label fx:id="activeBorrowsLabel" text="0" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Recent Transactions Table -->
            <Label text="Recent Transactions" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <TableView fx:id="recentTransactionsTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="recordIdColumn" text="Record ID" prefWidth="80"/>
                    <TableColumn fx:id="bookIdColumn" text="Book ID" prefWidth="80"/>
                    <TableColumn fx:id="memberIdColumn" text="Member ID" prefWidth="100"/>
                    <TableColumn fx:id="borrowDateColumn" text="Borrow Date" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
